step "build-multi-platform-manifest" {
    name = "Build Multi Platform Manifest"

    action {
        action_type = "Octopus.Script"
        environments = ["staging", "production"]
        properties = {
            Octopus.Action.Script.ScriptBody = <<-EOT
                #!/bin/bash
                echo "##octopus[stderr-progress]"
                set -eux
                
                targetHostName=$(get_octopusvariable "Docker.Registry.Target.Hostname")
                echo "Creating multi-arch manifests for registry: $targetHostName"
                echo $(get_octopusvariable "Docker.Registry.Target.Password") | docker login -u $(get_octopusvariable "Docker.Registry.Target.Username") --password-stdin $targetHostName
                
                fullVersion=$(get_octopusvariable "WorkerTools.Version.Full")
                latestMajorTag=$(get_octopusvariable "WorkerTools.Version.Major")
                latestMinorTag=$(get_octopusvariable "WorkerTools.Version.MajorMinor")
                
                semVerRegex="[0-9]+\.[0-9]+\.[0-9]+"
                if ! [[ $fullVersion =~ $semVerRegex ]]; then
                    echo "The tag $fullVersion should be a fully qualified SemVer tag"
                    exit 1
                fi
                
                dockerRepository=$(get_octopusvariable "Docker.Registry.Target.Repository")
                
                for tag in latest ${fullVersion} ${latestMajorTag} ${latestMinorTag}; do
                    echo "Creating multi-arch manifest for ${dockerRepository}:${tag}"
                    docker manifest create --amend ${dockerRepository}:${tag} \
                        $(get_octopusvariable "Docker.Image.OS.Tag.Ubuntu.2204.Full") \
                        $(get_octopusvariable "Docker.Image.OS.Tag.Ubuntu.2404.Full") \
                        $(get_octopusvariable "Docker.Image.OS.Tag.Windows.2022.Full") \
                        $(get_octopusvariable "Docker.Image.OS.Tag.Windows.2025.Full")
                    docker manifest push ${dockerRepository}:${tag}
                done
                EOT
            Octopus.Action.Script.ScriptSource = "Inline"
            Octopus.Action.Script.Syntax = "Bash"
            OctopusUseBundledTooling = "False"
        }
        worker_pool = "hosted-ubuntu"
    }
}

step "debug-variables" {
    name = "Debug Variables"

    action {
        action_type = "Octopus.Script"
        is_disabled = true
        is_required = true
        properties = {
            Octopus.Action.Script.ScriptBody = <<-EOT
                #!/bin/bash
                echo "##octopus[stderr-progress]"
                set -eux
                
                apt-get update
                apt install -y jq
                
                sourceHostName=$(get_octopusvariable "OctopusDockerRegistry.Hostname")
                targetHostName=$(get_octopusvariable "Docker.Target.Docker.Registry.Hostname")
                
                echo "Source Registry Name: $sourceHostName"
                echo "Target Registry Name: $targetHostName"
                
                # retry --times=3 --delay=5 -- skopeo login -u $(get_octopusvariable "OctopusDockerRegistry.Username") -p $(get_octopusvariable "OctopusDockerRegistry.Password") $sourceHostName
                # retry --times=3 --delay=5 -- skopeo login -u $(get_octopusvariable "Docker.Target.Docker.Registry.Username") -p $(get_octopusvariable "Docker.Target.Docker.Registry.Password") $targetHostName
                
                repositoryTagsJson=$(retry --times=3 --delay=5 -- skopeo list-tags docker://$(get_octopusvariable "OctopusDockerRegistry.WorkerTools.Repository"))
                
                osTag=$(get_octopusvariable "Docker.Image.Tag")
                fullyQualifiedTag=$(get_octopusvariable "Octopus.Release.Number")-"${osTag}"
                
                semVerRegex="[0-9]+\.[0-9]+\.[0-9]+\-.*"
                if ! [[ $fullyQualifiedTag =~ $semVerRegex ]]; then
                    echo "The tag $fullyQualifiedTag should be a fully qualified SemVer tag"
                    exit 1
                fi
                
                matchingSourceTag=$(jq -r --arg fullyQualifiedTag "$fullyQualifiedTag" '.Tags[] | select(.==$fullyQualifiedTag)' <<<"$repositoryTagsJson")
                
                if [ "$fullyQualifiedTag" != "$matchingSourceTag" ]; then
                    echo "The tag $fullyQualifiedTag could not be found in $sourceHostName"
                    exit 1
                fi
                
                latestMajorTag=$(get_octopusvariable "WorkerTools.Tags.LatestMajor")
                latestMinorTag=$(get_octopusvariable "WorkerTools.Tags.LatestMinor")
                
                echo "Image tag for promotion: $fullyQualifiedTag"
                
                # if [ "$sourceHostName" != "$targetHostName" ]; then
                #     echo "Pushing $fullyQualifiedTag tag to target registry"
                #     retry --times=6 --delay=10 -- skopeo copy --all docker://$(get_octopusvariable "OctopusDockerRegistry.WorkerTools.Repository"):$fullyQualifiedTag docker://$(get_octopusvariable "Docker.Target.Docker.Repository"):$fullyQualifiedTag
                # fi
                
                echo "Pushing floating tags to target registry:"
                echo $latestMajorTag
                echo $latestMinorTag
                echo $osTag
                # retry --times=6 --delay=10 -- skopeo copy --all docker://$(get_octopusvariable "OctopusDockerRegistry.WorkerTools.Repository"):$fullyQualifiedTag docker://$(get_octopusvariable "Docker.Target.Docker.Repository"):$latestMajorTag
                # retry --times=6 --delay=10 -- skopeo copy --all docker://$(get_octopusvariable "OctopusDockerRegistry.WorkerTools.Repository"):$fullyQualifiedTag docker://$(get_octopusvariable "Docker.Target.Docker.Repository"):$latestMinorTag
                # retry --times=6 --delay=10 -- skopeo copy --all docker://$(get_octopusvariable "OctopusDockerRegistry.WorkerTools.Repository"):$fullyQualifiedTag docker://$(get_octopusvariable "Docker.Target.Docker.Repository"):$osTag
                
                EOT
            Octopus.Action.Script.ScriptSource = "Inline"
            Octopus.Action.Script.Syntax = "Bash"
            OctopusUseBundledTooling = "False"
        }
        worker_pool = "hosted-ubuntu"

        container {
            feed = "docker-packages-octopushq"
            image = "#{skopeo-image-name}"
        }
    }
}